{
  "name": "@miniadk/tui",
  "version": "0.2.0",
  "description": "Ink-based terminal UI for the MiniADK Python ADK",
  "type": "module",
  "private": true,
  "main": "src/lib.ts",
  "module": "src/lib.ts",
  "types": "src/lib.ts",
  "exports": {
    ".": "./src/lib.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./theme": "./src/theme.ts",
    "./protocol": "./src/protocol.ts"
  },
  "scripts": {
    "dev": "bun src/index.tsx",
    "build": "bun build --compile --target=bun src/index.tsx --outfile dist/miniadk-tui",
    "build-linux-x64": "bun build --compile --target=bun-linux-x64 src/index.tsx --outfile dist/miniadk-tui-linux-x64",
    "build-linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.tsx --outfile dist/miniadk-tui-linux-arm64",
    "build-darwin-x64": "bun build --compile --target=bun-darwin-x64 src/index.tsx --outfile dist/miniadk-tui-darwin-x64",
    "build-darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.tsx --outfile dist/miniadk-tui-darwin-arm64",
    "build-windows-x64": "bun build --compile --target=bun-windows-x64 src/index.tsx --outfile dist/miniadk-tui-windows-x64.exe",
    "build-all": "bun run build-linux-x64 && bun run build-linux-arm64 && bun run build-darwin-x64 && bun run build-darwin-arm64 && bun run build-windows-x64"
  },
  "peerDependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "dependencies": {
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^14.1.3",
    "marked-terminal": "^7.2.1",
    "cli-highlight": "^2.1.11",
    "chalk": "^5.4.1",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "@types/react": "^18.3.12",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
